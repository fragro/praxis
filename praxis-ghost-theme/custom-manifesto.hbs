<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PRAXIS: The Manifesto</title>
  <meta name="description" content="Build the lifeboat. A manifesto for parallel democratic infrastructure." />
  <link rel="stylesheet" href="{{asset "css/style.css"}}" />
  <script src="{{asset "js/theme.js"}}"></script>
  <script defer src="https://analytics.praxisplan.org/script.js" data-website-id="be9bc5c6-212f-4bbf-af37-52bd922f3a61"></script>
  <script>
    (function() {
      var hash = '5e331ba24c2abe2500e2819de559ff65d06e830f7b795a7a3d264f8c769b6e1d';
      var match = document.cookie.match(/praxis_access=([a-f0-9]+)/);
      if (!match || match[1] !== hash) {
        document.documentElement.setAttribute('data-locked', 'true');
      }
    })();
  </script>
  <style>
    [data-locked="true"] #praxis-content { display: none !important; }
    [data-locked="true"] #praxis-gate { display: flex !important; }
    #praxis-gate { display: none; }
    body { display: block; background: var(--surface); }
    .manifesto { max-width: 720px; margin: 0 auto; padding: 80px 48px 120px; }
    .manifesto .doc-eyebrow { margin-bottom: 20px; }
    .manifesto .doc-title { font-size: 42px; line-height: 1.05; margin-bottom: 10px; }
    .manifesto .doc-subtitle {
      font-family: var(--font-display); font-size: 20px; font-weight: 500;
      color: var(--text-2); line-height: 1.3; margin-bottom: 48px; letter-spacing: -0.3px;
    }
    .m-section { margin-bottom: 56px; }
    .m-section-num {
      font-family: var(--font-mono); font-size: 9px; font-weight: 500;
      letter-spacing: 3px; text-transform: uppercase; color: var(--red); margin-bottom: 12px;
    }
    .m-section-title {
      font-family: var(--font-display); font-size: 22px; font-weight: 700;
      color: var(--black); line-height: 1.15; letter-spacing: -0.5px; margin-bottom: 20px;
    }
    .m-body { font-size: 15px; color: var(--text-1); line-height: 2; }
    .m-body p { margin-bottom: 20px; }
    .m-body p:last-child { margin-bottom: 0; }
    .m-body strong { font-weight: 600; color: var(--black); }
    .m-body em { font-style: italic; color: var(--text-2); }
    .m-pull {
      font-family: var(--font-display); font-size: 19px; font-weight: 600;
      color: var(--black); line-height: 1.45; letter-spacing: -0.3px;
      padding: 28px 0 28px 24px; border-left: 3px solid var(--red); margin: 36px 0;
    }
    .m-divider { width: 48px; height: 2px; background: var(--red); margin: 56px 0; }
    .m-closing {
      font-family: var(--font-display); font-size: 28px; font-weight: 700;
      color: var(--black); line-height: 1.2; letter-spacing: -0.6px;
      margin-top: 56px; margin-bottom: 16px;
    }
    .m-sig {
      font-family: var(--font-mono); font-size: 10px; color: var(--text-3);
      letter-spacing: 1.5px; text-transform: uppercase; margin-top: 64px;
      padding-top: 24px; border-top: 1px solid var(--border);
    }
    .m-link {
      display: inline-block; font-family: var(--font-display); font-size: 14px;
      font-weight: 600; color: var(--red); text-decoration: none; margin-top: 48px;
    }
    .m-link:hover { text-decoration: underline; }
    .theme-toggle-float {
      position: fixed; top: 20px; right: 20px; z-index: 100;
      display: flex; align-items: center; gap: 8px;
    }
  </style>
  {{ghost_head}}
</head>
<body>

<div id="praxis-gate">
  {{> members-gate}}
</div>

<div id="praxis-content">
  <div class="theme-toggle-float">
    <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle dark mode"></button>
  </div>

  {{#post}}
  {{{content}}}
  {{/post}}
</div>

{{ghost_foot}}
</body>
</html>
